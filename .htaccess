# iDEAGO Shield & URL Optimization Protocol

# Protect against directory listing (Privacy)
Options -Indexes

# Enable Rewrite Engine
RewriteEngine On

# 1. Externally redirect /example.php to /example
# This ensures that if someone visits the old .php link, they are redirected to the clean one.
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Internally map /example to /example.php
# This allows the server to find the file even when the extension is missing in the URL.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [NC,L]

# Prevent access to sensitive system files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php81” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
